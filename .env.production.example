# Copy this file to /home/ubuntu/interviewmate/.env.production on EC2.
# Do not commit the real .env.production file.

NODE_ENV=production
PORT=3000
HTTP_PORT=80

# Frontend build-time API base URL.
VITE_API_BASE_URL=/api/v1

# CORS origin used by the NestJS backend.
# Example: http://your-domain.com
CORS_ORIGIN=http://YOUR_EC2_PUBLIC_IP

# Backend database connection.
# In Docker Compose, DB_HOST must stay as "postgres".
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=interviewmate
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=interview_mate

# PostgreSQL container initialization.
POSTGRES_USER=interviewmate
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=interview_mate

# JWT secrets.
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AI settings.
# Use "mock" for initial infrastructure testing without OpenAI cost.
AI_MODE=mock
USE_MOCK_AI=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Upload settings.
UPLOAD_MAX_FILE_SIZE=10485760
